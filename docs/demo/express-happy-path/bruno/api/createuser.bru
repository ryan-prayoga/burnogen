meta {
  name: createUser
  type: http
  seq: 7
  tags: [
    api
  ]
}

post {
  url: {{baseUrl}}/api/v1/users
  body: json
  auth: bearer
}

params:query {
  search: {{search}}
  page: 1
  limit: 1
  order: {{order}}
}

headers {
  accept: application/json
  content-type: application/json
  X-Trace-Id: {{X-Trace-Id}}
  Authorization: {{Authorization}}
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "price": 1,
    "active": true,
    "name": "",
    "email": "",
    "age": 1,
    "role": "",
    "tags": [
      ""
    ]
  }
}

example {
  name: "201 Response"
  description: "Inferred helper response"

  request: {
    url: {{baseUrl}}/api/v1/users
    method: post
    mode: json
    params:query: {
      search: {{search}}
      page: 1
      limit: 1
      order: {{order}}
    }

    headers: {
      accept: application/json
      content-type: application/json
      X-Trace-Id: {{X-Trace-Id}}
      Authorization: {{Authorization}}
    }

    body:json: {
      {
        "price": 1,
        "active": true,
        "name": "",
        "email": "",
        "age": 1,
        "role": "",
        "tags": [
          ""
        ]
      }
    }
  }

  response: {
    headers: {
      Content-Type: application/json
    }

    status: {
      code: 201
      text: Created
    }

    body: {
      type: json
      content: '''
        {
          "success": true,
