            "id": 1,
            "name": "Jane Doe",
            "email": "user@example.com",
            "age": 18,
            "role": "user",
            "page": 1,
            "limit": 10,
            "search": "search",
            "order": "asc",
            "price": 1.5,
            "active": true,
            "tags": [],
            "traceId": "trace_123",
            "authorization": "Bearer token"
          }
        }
      '''
    }
  }
}

