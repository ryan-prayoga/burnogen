{
  "name": "brunogen",
  "version": "0.4.1",
  "description": "Scan Laravel, Express.js, and Go API projects, normalize them into OpenAPI, and emit ready-to-try Bruno collections.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": "dist/cli.js",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts --clean",
    "demo:laravel": "npm run build && node scripts/update-laravel-demo.js",
    "demo:express": "npm run build && node scripts/update-express-demo.js",
    "demo:go": "npm run build && node scripts/update-go-demo.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run build && node dist/cli.js --help"
  },
  "keywords": [
    "bruno",
    "openapi",
    "laravel",
    "express",
    "gin",
    "fiber",
    "echo",
    "cli"
  ],
  "author": "Ryan Prayoga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryan-prayoga/brunogen.git"
  },
  "bugs": {
    "url": "https://github.com/ryan-prayoga/brunogen/issues"
  },
  "homepage": "https://github.com/ryan-prayoga/brunogen#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
