{
  "name": "brunogen",
  "version": "0.1.0",
  "description": "Generate Bruno collections from Laravel and Go API source code.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": "dist/cli.js",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts --clean",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "bruno",
    "openapi",
    "laravel",
    "gin",
    "fiber",
    "echo",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryan-prayoga/burnogen-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ryan-prayoga/burnogen-cli/issues"
  },
  "homepage": "https://github.com/ryan-prayoga/burnogen-cli#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
